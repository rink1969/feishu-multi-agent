{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/your-org/feishu-community-agent-orchestration/schemas/agent.json",
  "title": "Agent Registration",
  "description": "飞书社区Agent注册信息标准格式",
  "type": "object",
  "required": ["agent_id", "name", "type", "capabilities", "status", "owner"],
  "properties": {
    "agent_id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "maxLength": 64,
      "description": "全局唯一标识，小写字母+数字+连字符"
    },
    "name": {
      "type": "string",
      "maxLength": 50,
      "description": "显示名称，群聊中@用"
    },
    "type": {
      "type": "string",
      "enum": ["creative", "reviewer", "entertainment", "general", "coder", "analyst"],
      "description": "Agent类型"
    },
    "capabilities": {
      "type": "array",
      "items": {"type": "string"},
      "minItems": 1,
      "description": "能力标签数组"
    },
    "status": {
      "type": "string",
      "enum": ["online", "busy", "offline", "error"],
      "description": "当前状态"
    },
    "owner": {
      "type": "string",
      "description": "所有者飞书用户open_id"
    },
    "endpoint": {
      "type": ["string", "null"],
      "format": "uri",
      "description": "本地服务端点（可选）"
    },
    "max_concurrent_tasks": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10,
      "default": 1,
      "description": "最大并行任务数"
    },
    "current_tasks": {
      "type": "array",
      "items": {"type": "string"},
      "description": "当前执行中的任务ID列表"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "last_heartbeat": {
      "type": "string",
      "format": "date-time",
      "description": "最后心跳时间"
    },
    "version": {
      "type": "string",
      "description": "Agent软件版本"
    }
  }
}
